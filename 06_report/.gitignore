# =============================================================================
# Git ignores for a LaTeX thesis project
# =============================================================================

# Compiled output. Track figure PDFs, ignore everything else.
# (gitignore does not support inline `#` comments — keep them on their own lines.)
*.pdf
!figures/*.pdf
!figures/**/*.pdf

# Auxiliary files
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
*.nav
*.snm
*.vrb
*.xdv
*.idx
*.ilg
*.ind

# todonotes
*.tdo

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# LaTeX backups
*~
*.bak
