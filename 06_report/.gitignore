# =============================================================================
# Git ignores for a LaTeX thesis project
# =============================================================================

# Compiled output. Track picture/logo PDFs shipped with the template, ignore the rest.
# (gitignore does not support inline `#` comments — keep them on their own lines.)
*.pdf
# DTU corporate logo PDFs under Pictures/Logos/ must remain tracked.
!Pictures/**/*.pdf

# Auxiliary files
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
*.nav
*.snm
*.vrb
*.xdv
*.idx
*.ilg
*.ind

# todonotes
*.tdo

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# LaTeX backups
*~
*.bak
